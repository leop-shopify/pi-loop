{
  "name": "pi-loop",
  "version": "1.0.4",
  "type": "module",
  "description": "Intelligent goals and scheduled loops for Pi.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "scheduled-tasks",
    "recurring-tasks",
    "goals",
    "software-quality",
    "scoring"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.0",
  "pi": {
    "extensions": [
      "./extensions/pi-loop/index.ts"
    ],
    "skills": [
      "skills"
    ]
  },
  "files": [
    "extensions/pi-loop/*.ts",
    "extensions/pi-loop/scoring",
    "skills",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "pnpm test && pnpm typecheck",
    "smoke": "node tests/smoke-pi-extension.mjs",
    "pack:dry": "pnpm pack --dry-run"
  },
  "dependencies": {
    "typebox": "1.2.14"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.2",
    "@earendil-works/pi-coding-agent": ">=0.80.2",
    "@earendil-works/pi-tui": ">=0.80.2"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@earendil-works/pi-tui": "0.80.2",
    "@types/node": "22.15.30",
    "typescript": "^5.9.3"
  }
}
