{
  "name": "pi-loop",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi extension for bounded, score-guided software engineering loops.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "agent-loop",
    "software-quality",
    "testing",
    "rails",
    "scoring"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.0",
  "pi": {
    "extensions": [
      "./extensions/pi-loop/index.ts"
    ]
  },
  "files": [
    "extensions",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "pnpm test && pnpm typecheck",
    "smoke": "node tests/smoke-pi-extension.mjs"
  },
  "dependencies": {
    "typebox": "1.2.14"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.74.2",
    "@earendil-works/pi-coding-agent": "0.74.2",
    "@earendil-works/pi-tui": "0.74.2",
    "@types/node": "22.15.30",
    "typescript": "^5.9.3"
  }
}
